<% layout("/layouts/boilerplate") %>

    <div class="row mt-4 mb-3 px-md-5 mx-auto" style="max-width: 1200px;">
        <div class="col-12">
            <h2 class="mb-4 fw-bold">Wishlists</h2>
        </div>
    </div>

    <div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-1 px-md-5 g-4 mx-auto"
        style="max-width: 1200px;">
        <% if (wishlist.length> 0) { %>
            <% for(listing of wishlist) { %>
                <a href="/listings/<%= listing._id %>" class="listing-link">
                    <div class="card col listing-card h-100">
                        <div class="position-relative">
                            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing_image">
                            <div class="heart-icon position-absolute top-0 end-0 m-3" style="z-index: 10;"
                                data-id="<%= listing._id %>"
                                onclick="event.preventDefault(); toggleWishlist(this, '<%= listing._id %>')">
                                <i class="fa-solid fa-heart fs-4" style="color: #FF385C;"></i>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="card-title mb-0"><b>
                                    <%= listing.location %>, <%= listing.country %>
                                </b></p>
                            <p class="text-muted small mb-0">Stay with <%= (listing.owner && listing.owner.email) ?
                                    listing.owner.email.split('@')[0] : 'Host' %>
                            </p>
                            <p class="text-muted small mb-1">Jun 10 - 15</p>
                            <p class="card-text"><b>&#8377; <%= Number(listing.price).toLocaleString("en-IN") %></b>
                                night</p>
                        </div>
                    </div>
                </a>
                <% } %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <div class="mb-4">
                                <i class="fa-regular fa-heart" style="font-size: 4rem; color: var(--text-muted);"></i>
                            </div>
                            <h4 class="fw-bold mb-3">Create your first wishlist</h4>
                            <p class="text-muted mb-4">As you search, click the heart icon to save your favorite places
                                and experiences to a wishlist.</p>
                            <a href="/listings" class="btn btn-dark px-4 py-2 fw-bold rounded-3">Start exploring</a>
                        </div>
                        <% } %>
    </div>

    <script>
        async function toggleWishlist(element, id) {
            try {
                const response = await fetch(`/listings/${id}/wishlist`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (data.success) {
                    // For wishlist page, we might want to remove the card immediately
                    element.closest('.listing-link').remove();
                    if (document.querySelectorAll('.listing-card').length === 0) {
                        location.reload(); // Show empty state
                    }
                }
            } catch (err) {
                console.error('Error:', err);
            }
        }
    </script>