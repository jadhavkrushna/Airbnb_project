<% layout("/layouts/boilerplate") %>

    <body>
        <div class="row mt-5">
            <div class="col-md-6 offset-md-3">
                <div class="card shadow border-0 p-4" style="border-radius: 1.5rem;">
                    <div class="card-body">
                        <h2 class="fw-bold mb-4">Personal info</h2>

                        <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" novalidate
                            class="needs-validation">

                            <!-- Profile Picture Section -->
                            <div class="d-flex align-items-center mb-5 gap-4">
                                <div class="position-relative">
                                    <img src="<%= user.profileImage.url %>" alt="profile_photo"
                                        class="rounded-circle shadow-sm border"
                                        style="width: 120px; height: 120px; object-fit: cover;">
                                </div>
                                <div>
                                    <h5 class="fw-bold mb-1">Your Photo</h5>
                                    <p class="text-muted small mb-3">This will be displayed on your profile and
                                        listings.</p>
                                    <label for="profileImage" class="btn btn-outline-dark btn-sm rounded-pill px-3">
                                        Change Photo
                                    </label>
                                    <input type="file" id="profileImage" name="profileImage" class="d-none">
                                </div>
                            </div>

                            <!-- Details Section -->
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label fw-bold">First name</label>
                                    <input type="text" name="firstName" id="firstName" value="<%= user.firstName %>"
                                        class="form-control rounded-3 py-2" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label fw-bold">Last name</label>
                                    <input type="text" name="lastName" id="lastName" value="<%= user.lastName %>"
                                        class="form-control rounded-3 py-2" required>
                                </div>
                                <div class="col-12 mt-4">
                                    <label for="email" class="form-label fw-bold">Email address</label>
                                    <input type="email" id="email" value="<%= user.email %>"
                                        class="form-control rounded-3 py-2 bg-light" disabled>
                                    <p class="text-muted xx-small mt-1">Email cannot be changed.</p>
                                </div>
                            </div>

                            <hr class="my-5">

                            <div class="d-flex justify-content-between align-items-center">
                                <a href="/listings" class="text-dark fw-bold">Cancel</a>
                                <button type="submit" class="btn btn-dark rounded-pill px-5 py-2 fw-bold">Save
                                    Changes</button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>
        </div>
    </body>