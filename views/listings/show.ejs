<% layout("/layouts/boilerplate") %>
    <!-- <script>
  const mapToken = "< process.env.MAP_TOKEN %>";
  mapboxgl.accessToken = "< process.env.MAP_TOKEN %>";
  const coordinates ="<JSON.stringify(listing.geometry.coordinates) %>";
</script> -->
    <!-- Header Section -->
    <div class="row mt-4 mb-3 px-md-5 mx-auto" style="max-width: 1200px;">
        <div class="col-12">
            <h2 class="mb-1" style="font-weight: 600; font-size: 1.8rem;">
                <%= listing.title %>
            </h2>
            <div class="d-flex align-items-center mb-3 text-muted" style="font-size: 0.95rem; font-weight: 500;">
                <i class="fa-solid fa-star me-2"></i> <span>
                    <%= listing.averageRating || "5.0" %>
                </span>
                <span class="mx-2">·</span>
                <a href="#reviews" class="text-dark fw-bold">
                    <%= listing.reviews.length %> reviews
                </a>
                <span class="mx-2">·</span>
                <span class="text-dark fw-bold text-decoration-underline">
                    <%= listing.location %>, <%= listing.country %>
                </span>
                <% let isWishlisted=false; if (currUser && currUser.wishlist) { isWishlisted=currUser.wishlist.some(id=>
                    id.toString() === listing._id.toString());
                    }
                    %>
                    <div class="ms-auto d-flex align-items-center gap-4">
                        <button
                            class="btn btn-link text-dark p-0 text-decoration-none d-flex align-items-center gap-2 wishlist-toggle-btn"
                            style="font-weight: 500;" data-id="<%= listing._id %>">
                            <i
                                class="<%= isWishlisted ? 'fa-solid wishlisted' : 'fa-regular not-wishlisted' %> fa-heart like-icon fs-6"></i>
                            <span class="text-decoration-underline">
                                <%= isWishlisted ? 'Saved' : 'Save' %>
                            </span>
                        </button>
                        <button class="btn btn-link text-dark p-0 text-decoration-none d-flex align-items-center gap-2"
                            style="font-weight: 500;" id="shareBtn">
                            <i class="fa-solid fa-share-nodes fs-6"></i>
                            <span class="text-decoration-underline">Share</span>
                        </button>
                    </div>
            </div>
        </div>
    </div>

    <!-- Hero Image Section -->
    <div class="row px-md-5 mx-auto mb-4" style="max-width: 1200px;">
        <div class="col-12 px-0 px-md-3">
            <div style="width: 100%; height: 60vh; border-radius: 1.5rem; overflow: hidden; background-color: #f7f7f7;">
                <img src="<%= listing.image.url %>" class="w-100 h-100 placeholder-glow" style="object-fit: cover;"
                    alt="listing_image">
            </div>
        </div>
    </div>

    <!-- Main Content & Sidebar -->
    <div class="row px-md-5 mx-auto" style="max-width: 1200px;">
        <!-- Left Content (70%) -->
        <div class="col-12 col-lg-8 pe-lg-5 mb-5">
            <div class="d-flex justify-content-between align-items-center mb-4 pb-4 border-bottom">
                <div>
                    <h4 class="mb-1 fw-bold">Hosted by <%= listing.owner ? listing.owner.email.split('@')[0]
                            : "Unknown User" %>
                    </h4>
                    <p class="text-muted mb-0">Superhost · 4 years hosting</p>
                </div>
                <div>
                    <i class="fa-solid fa-user-circle text-muted" style="font-size: 3.5rem;"></i>
                    <form action="/listings/<%= listing._id %>/inquiry" method="POST">
                        <button class="btn btn-outline-dark btn-sm fw-bold rounded-pill px-3 mt-2">Contact Host</button>
                    </form>
                </div>
            </div>

            <!-- Highlights -->
            <div class="mb-5 pb-4 border-bottom">
                <div class="d-flex align-items-center mb-4">
                    <i class="fa-solid fa-key fs-4 me-4 text-muted"></i>
                    <div>
                        <h6 class="mb-0 fw-bold">Self check-in</h6>
                        <p class="mb-0 text-muted">Check yourself in with the smartlock.</p>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-4">
                    <i class="fa-solid fa-medal fs-4 me-4 text-muted"></i>
                    <div>
                        <h6 class="mb-0 fw-bold">
                            <%= listing.owner ? listing.owner.email.split('@')[0] : "Host" %> is a Superhost
                        </h6>
                        <p class="mb-0 text-muted">Superhosts are experienced, highly rated hosts.</p>
                    </div>
                </div>
                <div class="d-flex align-items-center mb-0">
                    <i class="fa-solid fa-location-dot fs-4 me-4 text-muted"></i>
                    <div>
                        <h6 class="mb-0 fw-bold">Great location</h6>
                        <p class="mb-0 text-muted">95% of recent guests gave the location a 5-star rating.</p>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="mb-5 pb-4 border-bottom">
                <p class="card-text text-dark listing-description"
                    style="font-size: 1.05rem; line-height: 1.6; max-height: 100px; overflow: hidden; transition: max-height 0.3s ease;">
                    <%= listing.description %>
                </p>
                <button class="btn btn-link p-0 text-dark fw-bold text-decoration-underline border-0 bg-transparent"
                    id="showMoreDesc">Show more <i class="fa-solid fa-chevron-right ms-1 small"></i></button>
            </div>

            <!-- Where you'll sleep -->
            <div class="mb-5 pb-4 border-bottom">
                <h5 class="fw-bold mb-4">Where you'll sleep</h5>
                <div class="row g-3">
                    <div class="col-6 col-md-4">
                        <div class="card p-4 h-100 rounded-4 border">
                            <i class="fa-solid fa-bed fs-4 mb-3"></i>
                            <h6 class="fw-bold mb-1">Bedroom 1</h6>
                            <p class="text-muted small mb-0">1 queen bed</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="card p-4 h-100 rounded-4 border">
                            <i class="fa-solid fa-bed fs-4 mb-3"></i>
                            <h6 class="fw-bold mb-1">Bedroom 2</h6>
                            <p class="text-muted small mb-0">1 double bed</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Amenities -->
            <div class="mb-5 pb-4 border-bottom">
                <h5 class="fw-bold mb-4">What this place offers</h5>
                <div class="row g-3">
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-utensils me-3 fs-5 text-muted"></i>
                            <span>Kitchen</span>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-wifi me-3 fs-5 text-muted"></i>
                            <span>Wifi</span>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-briefcase me-3 fs-5 text-muted"></i>
                            <span>Dedicated workspace</span>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-car me-3 fs-5 text-muted"></i>
                            <span>Free parking on premises</span>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center">
                            <i class="fa-solid fa-snowflake me-3 fs-5 text-muted"></i>
                            <span>Air conditioning</span>
                        </div>
                    </div>
                    <div class="col-12 col-md-6 mb-2">
                        <div class="d-flex align-items-center text-decoration-line-through opacity-50">
                            <i class="fa-solid fa-bell-slash me-3 fs-5"></i>
                            <span>Smoke alarm</span>
                        </div>
                    </div>
                </div>
                <button class="btn btn-outline-dark fw-bold px-4 py-2 mt-4 rounded-3" data-bs-toggle="modal"
                    data-bs-target="#amenitiesModal">Show all amenities</button>
            </div>

            <!-- Amenities Modal -->
            <div class="modal fade" id="amenitiesModal" tabindex="-1" aria-labelledby="amenitiesModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg modal-dialog-scrollable">
                    <div class="modal-content border-0 shadow-lg rounded-4">
                        <div class="modal-header border-0 p-4">
                            <button type="button" class="btn-close ms-0" data-bs-dismiss="modal"
                                aria-label="Close"></button>
                        </div>
                        <div class="modal-body p-4 pt-0">
                            <h4 class="fw-bold mb-4" id="amenitiesModalLabel">What this place offers</h4>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Bathroom</h5>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-wind me-3 fs-5 text-muted"></i> Hairdryer</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-soap me-3 fs-5 text-muted"></i> Cleaning products</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-pump-soap me-3 fs-5 text-muted"></i> Shampoo</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-faucet me-3 fs-5 text-muted"></i> Hot water</div>
                                <div class="py-3 d-flex align-items-center"><i
                                        class="fa-solid fa-shower me-3 fs-5 text-muted"></i> Shower gel</div>
                            </div>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Bedroom and laundry</h5>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-shirt me-3 fs-5 text-muted"></i> Washing machine</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-rug me-3 fs-5 text-muted"></i> Hangers</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-bed me-3 fs-5 text-muted"></i> Bed linen (Cotton linen)</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-sheet-plastic me-3 fs-5 text-muted"></i> Extra pillows and
                                    blankets</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-clapperboard me-3 fs-5 text-muted"></i> Iron</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-folder me-3 fs-5 text-muted"></i> Clothes drying rack</div>
                                <div class="py-3 d-flex align-items-center"><i
                                        class="fa-solid fa-vault me-3 fs-5 text-muted"></i> Clothes storage: wardrobe
                                </div>
                            </div>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Entertainment</h5>
                                <div class="py-3 d-flex align-items-center"><i
                                        class="fa-solid fa-tv me-3 fs-5 text-muted"></i> 43-inch HDTV</div>
                            </div>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Heating and cooling</h5>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-snowflake me-3 fs-5 text-muted"></i> Air conditioning</div>
                                <div class="py-3 d-flex align-items-center"><i
                                        class="fa-solid fa-fan me-3 fs-5 text-muted"></i> Ceiling fan</div>
                            </div>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Home safety</h5>
                                <div class="py-3 border-bottom d-flex align-items-start">
                                    <i class="fa-solid fa-video me-3 fs-5 text-muted mt-1"></i>
                                    <div>
                                        <span>Exterior security cameras on property</span>
                                        <p class="text-muted small mb-0">One CCTV at entrance for guest safety</p>
                                    </div>
                                </div>
                                <div class="py-3 d-flex align-items-center"><i
                                        class="fa-solid fa-fire-extinguisher me-3 fs-5 text-muted"></i> Fire
                                    extinguisher</div>
                            </div>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Kitchen and dining</h5>
                                <div class="py-3 border-bottom d-flex align-items-start">
                                    <i class="fa-solid fa-kitchen-set me-3 fs-5 text-muted mt-1"></i>
                                    <div>
                                        <span>Kitchen</span>
                                        <p class="text-muted small mb-0">Space where guests can cook their own meals</p>
                                    </div>
                                </div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-ice-cream me-3 fs-5 text-muted"></i> Fridge</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-microchip me-3 fs-5 text-muted"></i> Microwave</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-blender me-3 fs-5 text-muted"></i> Cooking basics (Pots,
                                    pans, oil, salt and pepper)</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-wine-glass me-3 fs-5 text-muted"></i> Wine glasses</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-bread-slice me-3 fs-5 text-muted"></i> Toaster</div>
                                <div class="py-3 d-flex align-items-center"><i
                                        class="fa-solid fa-table me-3 fs-5 text-muted"></i> Dining table</div>
                            </div>

                            <div class="amenity-category mb-5">
                                <h5 class="fw-bold mb-3 fs-6">Services</h5>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-smoking me-3 fs-5 text-muted"></i> Smoking allowed</div>
                                <div class="py-3 border-bottom d-flex align-items-center"><i
                                        class="fa-solid fa-calendar-check me-3 fs-5 text-muted"></i> Long-term stays
                                    allowed</div>
                                <div class="py-3 d-flex align-items-start">
                                    <i class="fa-solid fa-user-shield me-3 fs-5 text-muted mt-1"></i>
                                    <div>
                                        <span>Self check-in</span>
                                        <p class="text-muted small mb-0">Building staff available 24/7</p>
                                    </div>
                                </div>
                            </div>

                            <div class="amenity-category mb-3">
                                <h5 class="fw-bold mb-3 fs-6">Not included</h5>
                                <div
                                    class="py-3 border-bottom d-flex align-items-center text-decoration-line-through opacity-50">
                                    <i class="fa-solid fa-bell-slash me-3 fs-5"></i> Smoke alarm
                                </div>
                                <div
                                    class="py-3 border-bottom d-flex align-items-center text-decoration-line-through opacity-50">
                                    <i class="fa-solid fa-mask-ventilation me-3 fs-5"></i> Carbon monoxide alarm
                                </div>
                                <div class="py-3 d-flex align-items-center text-decoration-line-through opacity-50"><i
                                        class="fa-solid fa-door-closed me-3 fs-5"></i> Private entrance</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Delete/Edit Actions -->
            <% if(currUser && listing.owner && currUser._id.equals(listing.owner._id)) { %>
                <div class="d-flex gap-3 mb-5 border-bottom pb-4">
                    <a href="/listings/<%= listing._id %>/edit" class="btn edit-btn px-4">Edit Listing</a>
                    <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
                        <button class="btn btn-dark px-4"
                            style="border-radius: 0.5rem; padding: 0.8rem 1.5rem; font-weight: 500;"> Delete
                            Listing</button>
                    </form>
                </div>
                <% } %>
                    <!-- Reviews Summary -->
                    <div id="reviews" class="mb-5">
                        <div class="d-flex align-items-center mb-4">
                            <i class="fa-solid fa-star me-2 fs-4"></i> <span class="fs-4 fw-bold">
                                <%= listing.averageRating || "5.0" %> · <%= listing.reviews.length %> reviews
                            </span>
                        </div>

                        <div class="row mb-5 g-4 border-bottom pb-4">
                            <div class="col-12 col-md-6">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-muted">Cleanliness</span>
                                    <div class="d-flex align-items-center w-50">
                                        <div class="progress flex-grow-1 bg-light" style="height: 4px;">
                                            <div class="progress-bar bg-dark" style="width: 98%;"></div>
                                        </div>
                                        <span class="ms-3 small fw-bold">4.9</span>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-muted">Accuracy</span>
                                    <div class="d-flex align-items-center w-50">
                                        <div class="progress flex-grow-1 bg-light" style="height: 4px;">
                                            <div class="progress-bar bg-dark" style="width: 100%;"></div>
                                        </div>
                                        <span class="ms-3 small fw-bold">5.0</span>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <span class="text-muted">Communication</span>
                                    <div class="d-flex align-items-center w-50">
                                        <div class="progress flex-grow-1 bg-light" style="height: 4px;">
                                            <div class="progress-bar bg-dark" style="width: 96%;"></div>
                                        </div>
                                        <span class="ms-3 small fw-bold">4.8</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-6">
                                <div class="col-12 col-md-11 ms-md-auto">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">Location</span>
                                        <div class="d-flex align-items-center w-50">
                                            <div class="progress flex-grow-1 bg-light" style="height: 4px;">
                                                <div class="progress-bar bg-dark" style="width: 100%;"></div>
                                            </div>
                                            <span class="ms-3 small fw-bold">5.0</span>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">Check-in</span>
                                        <div class="d-flex align-items-center w-50">
                                            <div class="progress flex-grow-1 bg-light" style="height: 4px;">
                                                <div class="progress-bar bg-dark" style="width: 98%;"></div>
                                            </div>
                                            <span class="ms-3 small fw-bold">4.9</span>
                                        </div>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span class="text-muted">Value</span>
                                        <div class="d-flex align-items-center w-50">
                                            <div class="progress flex-grow-1 bg-light" style="height: 4px;">
                                                <div class="progress-bar bg-dark" style="width: 94%;"></div>
                                            </div>
                                            <span class="ms-3 small fw-bold">4.7</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row g-4 mb-4">
                            <% for( review of listing.reviews){ %>
                                <div class="col-12 col-md-6">
                                    <div class="card h-100 border-0 p-2">
                                        <div class="card-body p-0">
                                            <div class="d-flex align-items-center mb-3">
                                                <i class="fa-solid fa-user-circle text-muted me-3"
                                                    style="font-size: 2.5rem;"></i>
                                                <div>
                                                    <h6 class="card-title fw-bold mb-0">
                                                        <%= review.author.email.split('@')[0] %>
                                                    </h6>
                                                    <p class="text-muted small mb-0">
                                                        <% const now=new Date(); const reviewDate=new
                                                            Date(review.createdAt); const diffTime=Math.abs(now -
                                                            reviewDate); const diffDays=Math.floor(diffTime / (1000 * 60
                                                            * 60 * 24)); const diffMonths=Math.floor(diffDays / 30); if
                                                            (diffDays===0) { %>
                                                            Just now
                                                            <% } else if (diffDays < 30) { %>
                                                                <%= diffDays %> days ago
                                                                    <% } else { %>
                                                                        <%= reviewDate.toLocaleDateString('en-US', {
                                                                            month: 'long' , year: 'numeric' }) %>
                                                                            <% } %>
                                                    </p>
                                                </div>
                                            </div>
                                            <div class="d-flex align-items-center mb-2">
                                                <p class="starability-result m-0" data-rating="<%= review.rating %>">
                                                </p>
                                            </div>
                                            <p class="card-text text-dark" style="line-height: 1.5;">
                                                <%= review.comment %>
                                            </p>
                                            <% if(currUser && currUser._id.equals(review.author._id)) { %>
                                                <form method="post" class="mt-3"
                                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                                                    <button
                                                        class="btn btn-sm btn-outline-dark fw-bold rounded-pill px-3">Delete</button>
                                                </form>
                                                <% } %>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                        </div>

                        <% if(currUser) {%>
                            <hr class="my-5">
                            <div class="p-4" style="background: var(--bg-light); border-radius: 1rem;">
                                <h4 class="fw-bold mb-4">Leave a Review</h4>
                                <form action="/listings/<%= listing.id %>/reviews" method="post" novalidate
                                    class="needs-validation">
                                    <div class="mb-4">
                                        <label for="rating" class="form-label fw-bold">Overall Rating</label>
                                        <fieldset class="starability-grow">
                                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]"
                                                value="1" checked aria-label="No rating" />
                                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                            <label for="first-rate1" title="Terrible">1 star</label>
                                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                            <label for="first-rate2" title="Not good">2 stars</label>
                                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                            <label for="first-rate3" title="Average">3 stars</label>
                                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                            <label for="first-rate4" title="Very good">4 stars</label>
                                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                            <label for="first-rate5" title="Amazing">5 stars</label>
                                        </fieldset>
                                    </div>
                                    <div class="mb-4">
                                        <label for="comment" class="form-label fw-bold">What was your experience
                                            like?</label>
                                        <textarea id="comment" cols="30" rows="5" class="form-control"
                                            style="border-radius: 0.8rem;" required name="review[comment]"
                                            placeholder="Share details of your own experience at this place"></textarea>
                                        <div class="invalid-feedback"> Please Add some Comments</div>
                                    </div>
                                    <button class="btn edit-btn px-4">Submit Review</button>
                                </form>
                            </div>
                            <% } %>
                    </div>
        </div>

        <!-- Right Content: Sticky Booking Card (30%) -->
        <div class="col-12 col-lg-4 position-relative">
            <div class="card shadow-md border-0 p-4 sticky-top mb-5"
                style="top: 100px; border-radius: 1.25rem; box-shadow: 0 6px 16px rgba(0,0,0,0.12); z-index: 1;">
                <div class="d-flex align-items-end mb-4">
                    <h4 class="fw-bold mb-0 me-1">&#8377; <%= Number(listing.price).toLocaleString("en-IN") %>
                    </h4>
                    <span class="text-muted pb-1"> night</span>
                </div>

                <!-- Fake Booking UI for aesthetics -->
                <div class="border rounded-4 mb-3" style="border-color: #B0B0B0 !important;">
                    <div class="d-flex border-bottom" style="border-color: #B0B0B0 !important;">
                        <div class="p-2 px-3 w-50 border-end" style="border-color: #B0B0B0 !important;">
                            <label class="d-block text-uppercase fw-bold" style="font-size: 0.65rem;">Check-in</label>
                            <input type="text" id="checkin" class="border-0 p-0 w-100"
                                style="outline: none; font-size: 0.9rem;" placeholder="Add date" readonly>
                        </div>
                        <div class="p-2 px-3 w-50">
                            <label class="d-block text-uppercase fw-bold" style="font-size: 0.65rem;">Checkout</label>
                            <input type="text" id="checkout" class="border-0 p-0 w-100"
                                style="outline: none; font-size: 0.9rem;" placeholder="Add date" readonly>
                        </div>
                    </div>
                    <div class="p-2 px-3 w-100">
                        <label class="d-block text-uppercase fw-bold" style="font-size: 0.65rem;">Guests</label>
                        <select class="border-0 p-0 w-100" style="outline: none; font-size: 0.9rem; appearance: none;">
                            <option>1 guest</option>
                            <option>2 guests</option>
                            <option>3 guests</option>
                            <option>4 guests</option>
                        </select>
                    </div>
                </div>

                <form action="/listings/<%= listing._id %>/book-now" method="POST">
                    <button class="btn w-100 py-3 mb-3 fw-bold text-white fs-6"
                        style="background-image: radial-gradient(circle at center, #FF385C 0%, #E61E4D 27.5%, #E31C5F 40%, #D70466 57.5%, #BD1E59 75%, #BD1E59 100%); border-radius: 0.5rem; border: none;">Reserve</button>
                </form>

                <p class="text-center text-muted small mb-4">You won't be charged yet</p>

                <div id="pricing-details" style="display: none;" data-price="<%= listing.price %>">
                    <div class="d-flex justify-content-between mb-2 pb-1 text-dark">
                        <span class="text-decoration-underline">&#8377; <%=
                                Number(listing.price).toLocaleString("en-IN") %>
                                x <span id="num-nights">0</span> nights</span>
                        <span>&#8377; <span id="base-price">0</span></span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 pb-3 border-bottom text-dark">
                        <span class="text-decoration-underline">Airbnb service fee (18% GST)</span>
                        <span>&#8377; <span id="tax-amount">0</span></span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold fs-6">
                        <span>Total before taxes</span>
                        <span>&#8377; <span id="total-price">0</span></span>
                    </div>
                </div>
                <div id="pricing-placeholder" class="text-center text-muted small">
                    Select dates to see total price
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 mt-5">
        <hr>
        <h3 class="fw-bold mb-4">Where you'll be</h3>
        <div id="map" style="height: 400px; width: 100%; border-radius: 1rem;" class="shadow-sm border"
            data-token="<%= mapToken %>" data-coordinates="<%= JSON.stringify(listing.geometry.coordinates) %>">
        </div>
        <p class="text-muted mt-3">
            <%= listing.location %>, <%= listing.country %>
        </p>
    </div>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', (event) => {
            const mapElement = document.getElementById("map");
            const mapToken = mapElement ? mapElement.getAttribute("data-token") : null;
            const coordinates = mapElement ? JSON.parse(mapElement.getAttribute("data-coordinates")) : null;

            // Mapbox Initialization
            if (mapToken && coordinates && typeof mapboxgl !== 'undefined') {
                mapboxgl.accessToken = mapToken;

                // Handle missing or default coordinates [0,0]
                const isDefaultLoc = coordinates[0] === 0 && coordinates[1] === 0;

                const map = new mapboxgl.Map({
                    container: 'map',
                    style: 'mapbox://styles/mapbox/streets-v12',
                    center: coordinates,
                    zoom: isDefaultLoc ? 1 : 14, // Tighter zoom for 3D view
                    pitch: 60, // Perspective angle
                    bearing: -17.6, // Slight rotation for 3D depth
                    antialias: true // Smoother edges for 3D buildings
                });

                // Add navigation controls (zoom in/out/rotate)
                map.addControl(new mapboxgl.NavigationControl());

                // Enable 3D Buildings Layer
                map.on('load', () => {
                    const layers = map.getStyle().layers;
                    const labelLayerId = layers.find(
                        (layer) => layer.type === 'symbol' && layer.layout['text-field']
                    ).id;

                    map.addLayer(
                        {
                            'id': 'add-3d-buildings',
                            'source': 'composite',
                            'source-layer': 'building',
                            'filter': ['==', 'extrude', 'true'],
                            'type': 'fill-extrusion',
                            'minzoom': 15,
                            'paint': {
                                'fill-extrusion-color': '#aaa',
                                'fill-extrusion-height': [
                                    'interpolate',
                                    ['linear'],
                                    ['zoom'],
                                    15,
                                    0,
                                    15.05,
                                    ['get', 'height']
                                ],
                                'fill-extrusion-base': [
                                    'interpolate',
                                    ['linear'],
                                    ['zoom'],
                                    15,
                                    0,
                                    15.05,
                                    ['get', 'min_height']
                                ],
                                'fill-extrusion-opacity': 0.6
                            }
                        },
                        labelLayerId
                    );
                });

                // Create a popup
                const popup = new mapboxgl.Popup({ offset: 25 })
                    .setHTML(`
                        <div class="px-2 py-1">
                            <h6 class="fw-bold mb-1"><%= listing.title %></h6>
                            <p class="text-muted small mb-0"><%= listing.location %></p>
                            ${isDefaultLoc ? `
                            <div class="mt-2 p-2 bg-light border-start border-danger border-3 rounded">
                                <p class="text-danger x-small fw-bold mb-1"><i class="fa-solid fa-triangle-exclamation"></i> Location not pinpointed</p>
                                <p class="text-muted xx-small mb-0">Tip: Edit this listing and save to refresh coordinates.</p>
                            </div>
                            ` : ''}
                        </div>
                    `);

                // Create and add the marker
                new mapboxgl.Marker({ color: "#FF385C" })
                    .setLngLat(coordinates)
                    .setPopup(popup)
                    .addTo(map);
            }

            // Wishlist functionality
            const wishlistBtn = document.querySelector(".wishlist-toggle-btn");
            if (wishlistBtn) {
                wishlistBtn.addEventListener("click", async () => {
                    const listingId = wishlistBtn.getAttribute("data-id");
                    const icon = wishlistBtn.querySelector("i");
                    const label = wishlistBtn.querySelector("span");

                    try {
                        const response = await fetch(`/listings/${listingId}/wishlist`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' }
                        });

                        if (response.status === 401) {
                            window.location.href = "/login";
                            return;
                        }

                        const data = await response.json();
                        if (data.success) {
                            if (data.added) {
                                icon.classList.remove("fa-regular");
                                icon.classList.add("fa-solid");
                                icon.style.color = "#FF385C";
                                label.innerText = "Saved";
                            } else {
                                icon.classList.remove("fa-solid");
                                icon.classList.add("fa-regular");
                                icon.style.color = "var(--text-dark)";
                                label.innerText = "Save";
                            }
                        }
                    } catch (err) {
                        console.error("Error toggling wishlist:", err);
                    }
                });
            }

            // Description toggle
            const showMoreBtn = document.getElementById("showMoreDesc");
            const descriptionText = document.querySelector(".listing-description");
            if (showMoreBtn && descriptionText) {
                showMoreBtn.addEventListener("click", () => {
                    if (descriptionText.style.maxHeight === "100px") {
                        descriptionText.style.maxHeight = "none";
                        showMoreBtn.innerHTML = 'Show less <i class="fa-solid fa-chevron-up ms-1 small"></i>';
                    } else {
                        descriptionText.style.maxHeight = "100px";
                        showMoreBtn.innerHTML = 'Show more <i class="fa-solid fa-chevron-right ms-1 small"></i>';
                    }
                });
            }

            // Share functionality
            const shareBtn = document.getElementById("shareBtn");
            if (shareBtn) {
                shareBtn.addEventListener("click", async () => {
                    const shareData = {
                        title: "<%= listing.title %>",
                        text: "Check out this place on Wanderlust!",
                        url: window.location.href
                    };

                    try {
                        if (navigator.share) {
                            await navigator.share(shareData);
                        } else {
                            await navigator.clipboard.writeText(window.location.href);
                            alert("Link copied to clipboard!");
                        }
                    } catch (err) {
                        console.error("Error sharing:", err);
                    }
                });
            }

            // Booking Calendar
            const checkinInput = document.getElementById("checkin");
            const checkoutInput = document.getElementById("checkout");
            const pricingDetails = document.getElementById("pricing-details");
            const nightPrice = pricingDetails ? Number(pricingDetails.getAttribute("data-price")) : 0;

            if (checkinInput && checkoutInput && typeof flatpickr !== 'undefined') {
                flatpickr("#checkin, #checkout", {
                    mode: "range",
                    minDate: "today",
                    dateFormat: "Y-m-d",
                    onChange: function (selectedDates, dateStr, instance) {
                        if (selectedDates.length === 2) {
                            const checkinDate = selectedDates[0];
                            const checkoutDate = selectedDates[1];
                            const diffTime = Math.abs(checkoutDate - checkinDate);
                            const diffNights = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                            if (diffNights > 0) {
                                checkinInput.value = checkinDate.toISOString().split('T')[0];
                                checkoutInput.value = checkoutDate.toISOString().split('T')[0];

                                const basePrice = diffNights * nightPrice;
                                const taxAmount = Math.round(basePrice * 0.18);
                                const totalPrice = basePrice + taxAmount;

                                numNightsSpan.innerText = diffNights;
                                basePriceSpan.innerText = basePrice.toLocaleString("en-IN");
                                taxAmountSpan.innerText = taxAmount.toLocaleString("en-IN");
                                totalPriceSpan.innerText = totalPrice.toLocaleString("en-IN");

                                pricingDetails.style.display = "block";
                                pricingPlaceholder.style.display = "none";
                            }
                        } else {
                            pricingDetails.style.display = "none";
                            pricingPlaceholder.style.display = "block";
                        }
                    }
                });
            }
        });
    </script>