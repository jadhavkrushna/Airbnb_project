<% layout("/layouts/boilerplate") %>
    <div class="row mt-3">
        <div class="alert alert-danger col-6 offset-3" role="alert">
            <h4 class="alert-heading">
                <%= message %>
            </h4>
            <% if (stack) { %>
                <hr>
                <p class="mb-0">
                    <%= stack %>
                </p>
                <% } %>
        </div>
    </div>